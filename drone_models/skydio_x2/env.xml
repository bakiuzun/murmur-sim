<mujoco model="urban_mjx_safe">

  <include file="x2_safe.xml"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <asset>
    <material name="ground" rgba="0.2 0.2 0.2 1"/>
    <material name="obs" rgba="0.6 0.6 0.6 1"/>
    <material name="goal" rgba="0.1 0.9 0.2 1"/>
  </asset>

  <worldbody>

    <!-- GROUND -->
    <geom type="plane" size="50 50 0.1" material="ground"/>

    <light pos="0 0 10"/>

    <!-- OBSTACLES (ONLY CAPSULE + SPHERE) -->
    <body name="obs1" pos="3 0 1">
      <geom type="capsule" size="0.3 1.2" material="obs"/>
    </body>

    <body name="obs2" pos="-2 2 1">
      <geom type="sphere" size="0.5" material="obs"/>
    </body>

    <body name="obs3" pos="0 -3 1">
      <geom type="capsule" size="0.4 1.0" material="obs"/>
    </body>

    <!-- GOAL -->
    <body name="goal" pos="5 5 1">
      <geom type="sphere" size="0.2" material="goal"/>
    </body>

    <!-- CAMERA -->
    <camera name="track" pos="0 -6 3"/>

  </worldbody>

</mujoco>